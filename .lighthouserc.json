{
  "ci": {
    "collect": {
      "staticDistDir": "./website/build",
      "url": [
        "http://localhost/index.html",
        "http://localhost/docs.html",
        "http://localhost/docs/overview/supply-chain.html",
        "http://localhost/devsecops/intro.html",
        "http://localhost/ai-coding/intro.html",
        "http://localhost/reference/samples/sbom.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    }
  }
}
